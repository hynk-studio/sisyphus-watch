{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sisyphus_watch/schemas/sisyphus_schema.json",
  "title": "Sisyphus Watch Demo Schema",
  "description": "Schema for synthetic Kaggle demo records used by Sisyphus Watch.",
  "$defs": {
    "source_record": {
      "type": "object",
      "required": [
        "source_id",
        "source_type",
        "actor",
        "title",
        "published_at",
        "retrieved_at",
        "reliability_note",
        "limitations",
        "is_synthetic_demo_fixture",
        "text"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^src_" },
        "source_type": { "type": "string" },
        "actor": { "type": "string" },
        "title": { "type": "string" },
        "published_at": { "type": "string" },
        "retrieved_at": { "type": "string" },
        "reliability_note": { "type": "string" },
        "limitations": { "type": "string" },
        "is_synthetic_demo_fixture": { "const": true },
        "text": { "type": "string", "minLength": 80 }
      },
      "additionalProperties": true
    },
    "fact": {
      "type": "object",
      "required": ["fact_id", "text", "source_ids", "confidence", "source_bound"],
      "properties": {
        "fact_id": { "type": "string", "pattern": "^fact_" },
        "text": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^src_" }, "minItems": 1 },
        "confidence": { "type": "string" },
        "source_bound": { "const": true }
      },
      "additionalProperties": true
    },
    "actor_claim": {
      "type": "object",
      "required": ["claim_id", "actor", "claim_text", "source_ids", "claim_type", "status"],
      "properties": {
        "claim_id": { "type": "string", "pattern": "^claim_" },
        "actor": { "type": "string" },
        "claim_text": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^src_" }, "minItems": 1 },
        "claim_type": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "action": {
      "type": "object",
      "required": ["action_id", "actor", "action_text", "source_ids", "action_type", "date"],
      "properties": {
        "action_id": { "type": "string", "pattern": "^action_" },
        "actor": { "type": "string" },
        "action_text": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^src_" }, "minItems": 1 },
        "action_type": { "type": "string" },
        "date": { "type": "string" }
      },
      "additionalProperties": true
    },
    "interpretation": {
      "type": "object",
      "required": [
        "interpretation_id",
        "title",
        "interpretation_text",
        "evidence_ids",
        "alternative_interpretations",
        "risk_notes",
        "confidence"
      ],
      "properties": {
        "interpretation_id": { "type": "string", "pattern": "^interp_" },
        "title": { "type": "string" },
        "interpretation_text": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "alternative_interpretations": { "type": "array", "items": { "type": "string" } },
        "risk_notes": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counter_branch": {
      "type": "object",
      "required": [
        "counter_branch_id",
        "title",
        "counter_text",
        "target_id",
        "target_type",
        "evidence_ids",
        "confidence"
      ],
      "properties": {
        "counter_branch_id": { "type": "string", "pattern": "^counter_" },
        "title": { "type": "string" },
        "counter_text": { "type": "string" },
        "target_id": { "type": "string" },
        "target_type": { "type": "string", "enum": ["interpretation", "claim", "column"] },
        "evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence": { "type": "string" }
      },
      "additionalProperties": true
    },
    "bias_note": {
      "type": "object",
      "required": ["bias_note_id", "source_id", "bias_type", "note_text", "why_labeled", "evidence_value"],
      "properties": {
        "bias_note_id": { "type": "string", "pattern": "^bias_" },
        "source_id": { "type": "string", "pattern": "^src_" },
        "bias_type": { "type": "string" },
        "note_text": { "type": "string" },
        "why_labeled": { "type": "string" },
        "evidence_value": { "type": "string" }
      },
      "additionalProperties": true
    },
    "version_diff": {
      "type": "object",
      "required": [
        "diff_id",
        "from_version",
        "to_version",
        "previous_judgment",
        "updated_judgment",
        "new_evidence_ids",
        "confidence_delta",
        "unchanged_uncertainties"
      ],
      "properties": {
        "diff_id": { "type": "string", "pattern": "^diff_" },
        "from_version": { "type": "string" },
        "to_version": { "type": "string" },
        "previous_judgment": { "type": "string" },
        "updated_judgment": { "type": "string" },
        "new_evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence_delta": { "type": "object", "additionalProperties": { "type": "string" } },
        "unchanged_uncertainties": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "version_event": {
      "type": "object",
      "required": [
        "version_id",
        "version_label",
        "date",
        "trigger",
        "summary",
        "evidence_ids",
        "judgment_at_version",
        "confidence_at_version",
        "open_questions"
      ],
      "properties": {
        "version_id": { "type": "string", "pattern": "^version_" },
        "version_label": { "type": "string" },
        "date": { "type": "string" },
        "trigger": { "type": "string" },
        "summary": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "judgment_at_version": { "type": "string" },
        "confidence_at_version": { "type": "string" },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "claim_drift": {
      "type": "object",
      "required": [
        "drift_id",
        "target_claim_id",
        "from_status",
        "to_status",
        "direction",
        "driver_evidence_ids",
        "drift_summary",
        "current_handling"
      ],
      "properties": {
        "drift_id": { "type": "string", "pattern": "^drift_" },
        "target_claim_id": { "type": "string", "pattern": "^claim_" },
        "from_status": { "type": "string" },
        "to_status": { "type": "string" },
        "direction": {
          "type": "string",
          "enum": ["strengthened", "weakened", "narrowed", "corrected", "unresolved"]
        },
        "driver_evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "drift_summary": { "type": "string" },
        "current_handling": { "type": "string" }
      },
      "additionalProperties": true
    },
    "graph_node": {
      "type": "object",
      "required": ["node_id", "node_type", "label", "ref_id", "summary"],
      "properties": {
        "node_id": { "type": "string", "pattern": "^node_" },
        "node_type": {
          "type": "string",
          "enum": [
            "source",
            "fact",
            "actor_claim",
            "action",
            "interpretation",
            "counter_branch",
            "version_event",
            "claim_drift",
            "version_diff",
            "verdict",
            "unresolved_question",
            "bias_note"
          ]
        },
        "label": { "type": "string" },
        "ref_id": { "type": "string" },
        "summary": { "type": "string" },
        "confidence": { "type": "string" },
        "source_bound": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "graph_edge": {
      "type": "object",
      "required": ["edge_id", "source_node_id", "target_node_id", "edge_type", "label"],
      "properties": {
        "edge_id": { "type": "string", "pattern": "^edge_" },
        "source_node_id": { "type": "string", "pattern": "^node_" },
        "target_node_id": { "type": "string", "pattern": "^node_" },
        "edge_type": {
          "type": "string",
          "enum": [
            "source_supports_fact",
            "source_contains_claim",
            "source_describes_action",
            "source_contains_bias_note",
            "fact_supports_interpretation",
            "claim_supports_interpretation",
            "action_supports_interpretation",
            "evidence_supports_counter_branch",
            "counter_branch_targets_interpretation",
            "counter_branch_targets_claim",
            "timeline_event_uses_evidence",
            "timeline_event_updates_judgment",
            "claim_drift_targets_claim",
            "evidence_drives_claim_drift",
            "version_diff_uses_evidence",
            "version_diff_updates_verdict",
            "verdict_depends_on_interpretation",
            "verdict_tempered_by_counter_branch",
            "verdict_has_unresolved_question",
            "bias_note_attaches_to_interpretation",
            "bias_note_attaches_to_verdict"
          ]
        },
        "label": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      },
      "additionalProperties": true
    },
    "primary_graph_path": {
      "type": "object",
      "required": ["path_id", "label", "node_ids", "edge_ids", "summary"],
      "properties": {
        "path_id": { "type": "string", "pattern": "^path_" },
        "label": { "type": "string" },
        "node_ids": { "type": "array", "items": { "type": "string", "pattern": "^node_" }, "minItems": 2 },
        "edge_ids": { "type": "array", "items": { "type": "string", "pattern": "^edge_" }, "minItems": 1 },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "claim_graph": {
      "type": "object",
      "required": ["graph_id", "nodes", "edges", "graph_summary", "primary_paths", "unresolved_edges"],
      "properties": {
        "graph_id": { "type": "string", "pattern": "^graph_" },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/graph_node" }, "minItems": 1 },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/graph_edge" }, "minItems": 1 },
        "graph_summary": { "type": "string" },
        "primary_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/primary_graph_path" },
          "minItems": 1
        },
        "unresolved_edges": { "type": "array", "items": { "$ref": "#/$defs/graph_edge" } }
      },
      "additionalProperties": true
    },
    "selected_subgraph": {
      "type": "object",
      "required": [
        "subgraph_id",
        "center_ref_id",
        "radius",
        "nodes",
        "edges",
        "summary",
        "included_ref_ids",
        "node_type_counts",
        "edge_type_counts",
        "excluded_node_count",
        "excluded_edge_count"
      ],
      "properties": {
        "subgraph_id": { "type": "string", "pattern": "^subgraph_" },
        "center_ref_id": { "type": "string" },
        "radius": { "type": "integer", "minimum": 0 },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/graph_node" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/graph_edge" } },
        "summary": { "type": "string" },
        "included_ref_ids": { "type": "array", "items": { "type": "string" } },
        "node_type_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "edge_type_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "excluded_node_count": { "type": "integer", "minimum": 0 },
        "excluded_edge_count": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" }
      },
      "additionalProperties": true
    },
    "graph_packet": {
      "type": "object",
      "required": [
        "packet_id",
        "packet_version",
        "packet_type",
        "canonical_card_id",
        "focus_ref_id",
        "graph_id",
        "graph_summary",
        "primary_paths",
        "node_count",
        "edge_count",
        "node_type_counts",
        "edge_type_counts",
        "selected_subgraph",
        "reuse_guidance",
        "limitations"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^graph_packet_" },
        "packet_version": { "const": "0.5" },
        "packet_type": { "const": "sisyphus_graph_packet" },
        "canonical_card_id": { "type": "string" },
        "focus_ref_id": { "type": ["string", "null"] },
        "graph_id": { "type": "string", "pattern": "^graph_" },
        "graph_summary": { "type": "string" },
        "primary_paths": { "type": "array", "items": { "type": "object" } },
        "node_count": { "type": "integer", "minimum": 0 },
        "edge_count": { "type": "integer", "minimum": 0 },
        "node_type_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "edge_type_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "selected_subgraph": {
          "anyOf": [
            { "$ref": "#/$defs/selected_subgraph" },
            { "type": "null" }
          ]
        },
        "reuse_guidance": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "reviewer_packet": {
      "type": "object",
      "required": [
        "packet_id",
        "packet_version",
        "packet_type",
        "card_id",
        "preset_id",
        "focus_ref_id",
        "answer_summary",
        "query_result",
        "agent_instructions",
        "limitations"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^reviewer_packet_" },
        "packet_version": { "const": "0.6" },
        "packet_type": { "const": "sisyphus_reviewer_packet" },
        "card_id": { "type": "string", "pattern": "^news_" },
        "preset_id": {
          "type": "string",
          "enum": [
            "claim_status_review",
            "verdict_change_review",
            "counter_branch_review",
            "next_agent_handoff"
          ]
        },
        "focus_ref_id": { "type": ["string", "null"] },
        "answer_summary": { "type": "string" },
        "query_result": {
          "type": "object",
          "required": [
            "preset_id",
            "preset_title",
            "question",
            "card_id",
            "focus_ref_id",
            "answer_summary",
            "supporting_nodes",
            "supporting_edges",
            "paths_to_verdict",
            "unresolved_questions",
            "recommended_next_checks",
            "reuse_guidance"
          ],
          "properties": {
            "preset_id": { "type": "string" },
            "preset_title": { "type": "string" },
            "question": { "type": "string" },
            "card_id": { "type": "string", "pattern": "^news_" },
            "focus_ref_id": { "type": ["string", "null"] },
            "focus_node": {
              "anyOf": [
                { "$ref": "#/$defs/graph_node" },
                { "type": "null" }
              ]
            },
            "answer_summary": { "type": "string" },
            "supporting_nodes": { "type": "array", "items": { "$ref": "#/$defs/graph_node" } },
            "supporting_edges": { "type": "array", "items": { "$ref": "#/$defs/graph_edge" } },
            "paths_to_verdict": { "type": "array", "items": { "type": "object" } },
            "selected_subgraph": {
              "anyOf": [
                { "$ref": "#/$defs/selected_subgraph" },
                { "type": "null" }
              ]
            },
            "unresolved_questions": { "type": "array", "items": { "type": "string" } },
            "recommended_next_checks": { "type": "array", "items": { "type": "string" } },
            "reuse_guidance": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "agent_instructions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scenario_authoring_template": {
      "type": "object",
      "required": [
        "scenario_id",
        "scenario_name",
        "title",
        "public_interest_reason",
        "summary",
        "source_fixtures",
        "expected_facts",
        "expected_actor_claims",
        "expected_actions",
        "expected_interpretations",
        "expected_counter_branches",
        "expected_bias_notes",
        "expected_version_timeline",
        "expected_claim_drift",
        "expected_version_diff",
        "expected_editorial_verdict",
        "authoring_notes"
      ],
      "properties": {
        "scenario_id": { "type": "string" },
        "scenario_name": { "type": "string" },
        "title": { "type": "string" },
        "public_interest_reason": { "type": "string" },
        "summary": {
          "anyOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "source_fixtures": { "type": "array", "items": { "type": "object" }, "minItems": 3 },
        "expected_facts": { "type": "array", "items": { "type": "object" }, "minItems": 3 },
        "expected_actor_claims": { "type": "array", "items": { "type": "object" }, "minItems": 2 },
        "expected_actions": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "expected_interpretations": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "expected_counter_branches": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "expected_bias_notes": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "expected_version_timeline": { "type": "array", "items": { "type": "object" }, "minItems": 2 },
        "expected_claim_drift": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "expected_version_diff": { "type": "object" },
        "expected_editorial_verdict": { "type": "object" },
        "authoring_notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scenario_authoring_checklist": {
      "type": "object",
      "required": [
        "checklist_id",
        "scenario_id",
        "scenario_name",
        "required_sections",
        "passed_sections",
        "missing_sections",
        "warnings",
        "ready_for_card_authoring",
        "next_authoring_steps"
      ],
      "properties": {
        "checklist_id": { "type": "string", "pattern": "^scenario_checklist_" },
        "scenario_id": { "type": "string" },
        "scenario_name": { "type": "string" },
        "required_sections": { "type": "array", "items": { "type": "string" } },
        "passed_sections": { "type": "array", "items": { "type": "string" } },
        "missing_sections": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "ready_for_card_authoring": { "type": "boolean" },
        "next_authoring_steps": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scenario_authoring_packet": {
      "type": "object",
      "required": [
        "packet_id",
        "packet_version",
        "packet_type",
        "scenario_id",
        "scenario_name",
        "template_errors",
        "checklist",
        "news_card_skeleton",
        "authoring_guidance",
        "limitations"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^scenario_authoring_packet_" },
        "packet_version": { "const": "0.7" },
        "packet_type": { "const": "sisyphus_scenario_authoring_packet" },
        "scenario_id": { "type": "string" },
        "scenario_name": { "type": "string" },
        "template_errors": { "type": "array", "items": { "type": "string" } },
        "checklist": { "$ref": "#/$defs/scenario_authoring_checklist" },
        "news_card_skeleton": { "type": "object" },
        "authoring_guidance": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "editorial_verdict": {
      "type": "object",
      "required": ["verdict_id", "short_label", "verdict_text", "confidence", "reader_warnings"],
      "properties": {
        "verdict_id": { "type": "string", "pattern": "^verdict_" },
        "short_label": { "type": "string" },
        "verdict_text": { "type": "string" },
        "confidence": { "type": "string" },
        "reader_warnings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "news_card": {
      "type": "object",
      "required": [
        "card_id",
        "record_type",
        "card_type",
        "title",
        "scenario_name",
        "version",
        "created_at",
        "is_synthetic_demo_fixture",
        "summary_3_line",
        "image_prompt",
        "source_ids",
        "source_hygiene_note",
        "facts",
        "actor_claims",
        "actions",
        "interpretations",
        "counter_branches",
        "bias_notes",
        "version_diff",
        "version_timeline",
        "claim_drift",
        "claim_graph",
        "editorial_verdict"
      ],
      "properties": {
        "card_id": { "type": "string", "pattern": "^news_" },
        "record_type": { "const": "news_card" },
        "card_type": { "type": "string" },
        "title": { "type": "string" },
        "scenario_name": { "type": "string" },
        "version": { "type": "string" },
        "created_at": { "type": "string" },
        "is_synthetic_demo_fixture": { "const": true },
        "summary_3_line": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 3 },
        "image_prompt": {
          "type": "object",
          "required": ["label", "prompt"],
          "properties": {
            "label": { "const": "Generated visual summary, not evidence" },
            "prompt": { "type": "string" }
          },
          "additionalProperties": true
        },
        "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^src_" }, "minItems": 1 },
        "source_hygiene_note": { "type": "string" },
        "facts": { "type": "array", "items": { "$ref": "#/$defs/fact" }, "minItems": 3 },
        "actor_claims": { "type": "array", "items": { "$ref": "#/$defs/actor_claim" }, "minItems": 2 },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action" }, "minItems": 1 },
        "interpretations": { "type": "array", "items": { "$ref": "#/$defs/interpretation" }, "minItems": 1 },
        "counter_branches": { "type": "array", "items": { "$ref": "#/$defs/counter_branch" }, "minItems": 1 },
        "bias_notes": { "type": "array", "items": { "$ref": "#/$defs/bias_note" }, "minItems": 1 },
